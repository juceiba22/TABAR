rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // FUNCIONES AUXILIARES DE SEGURIDAD
    // =========================================================================

    // Verifica si el usuario actual tiene rol de Administrador/Fideicomiso
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Verifica si el usuario está autenticado en la plataforma
    function isAuthenticated() {
      return request.auth != null;
    }

    // =========================================================================
    // REGLAS POR COLECCIÓN
    // =========================================================================

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Colección de Campañas (CRÍTICO: Solo Admin puede modificar)
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Colección de Balances Globales (CRÍTICO: Solo Admin puede modificar)
    match /balances/{balanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Logs de Auditoría
    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Solicitudes de Compra
    match /purchase_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Órdenes de Compra (Acopiador / Industria)
    match /purchase_orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Solicitudes de Financiamiento (Acopiador / Industria)
    match /financing_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Tokenizaciones del Productor
    match /producer_tokenizations/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.productorOwner;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.productorOwner == request.auth.uid);
    }

    // Asociaciones de Productores (Cooperativas Digitales)
    match /producer_associations/{associationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Permite actualizar si el usuario es miembro de la asociación o es administrador
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.productoresUIDs != null && request.auth.uid in resource.data.productoresUIDs) ||
        (request.resource.data.productoresUIDs != null && request.auth.uid in request.resource.data.productoresUIDs)
      );
      allow delete: if isAuthenticated() && resource.data.creadoPor == request.auth.uid;
    }

    // Carga de POAs (Estado Nacional)
    match /poa_uploads/{poaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Novedades FET (Estado Nacional)
    match /novedades_fet/{novedadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Operaciones de Dealers
    match /dealer_operations/{operationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.dealerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.dealerId == request.auth.uid;
    }

    // Notificaciones
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // Sistema de Chat Privado
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Mensajes del Chat
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && 
          request.resource.data.senderId == request.auth.uid;
      }
    }

    // Denegación por defecto para cualquier otra ruta no especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}